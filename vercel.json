{
  "version": 2,
  "rewrites": [
    { "source": "/", "destination": "/api/root" },
    { "source": "/index.html", "destination": "/api/root" }
  ],
  "functions": {
    "api/root.py": { "maxDuration": 30 },
    "api/fullpage.py": {
      "includeFiles": "api/root_index.html",
      "maxDuration": 30
    },
    "api/index.py": {
      "includeFiles": "api/root_index.html",
      "maxDuration": 30
    }
  }
}
