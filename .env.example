# VPN BOT — пример конфигурации
# Скопируйте: cp .env.example .env  и заполните значения

# === Обязательные ===
BOT_TOKEN=123456:ABC-DEF...
ADMIN_IDS=123456789,987654321
DATABASE_URL=sqlite:///vpn_bot.db
# или PostgreSQL: postgresql://user:password@host:5432/dbname

# === ЮKassa (оплата) ===
YOOKASSA_SHOP_ID=123456
YOOKASSA_SECRET_KEY=live_xxx...

# === Mini App и API ===
# Продакшен (пример): домен API = bitecosystem.ru, Vercel = bitvpn.vercel.app
WEBAPP_URL=https://bitvpn.vercel.app?api=https://bitecosystem.ru
MINIAPP_API_URL=https://bitecosystem.ru
# Опционально: абсолютный путь к лендингу для GET / (если папка website/ не рядом с api_miniapp.py на сервере)
# WEBSITE_INDEX_PATH=/opt/vpn-bot/website/index.html
BOT_USERNAME=YourBotName_bot

# === Поддержка ===
SUPPORT_USERNAME=support_username
SUPPORT_CHAT_ID=

# === VPN (Happ / свой сервер) ===
VPN_SERVER_URL=
VPN_API_KEY=
#
# Happ — два домена (обязательно не путать местами):
#   HAPP_API_URL          → поддомен api: add-install (GET /api/add-install). Пример: https://api.happ-proxy.com
#   HAPP_ADD_DOMAIN_URL   → «вторая база» без api: list-install, list-hwid, delete-hwid, add-domain. Пример: https://happ-proxy.com
# На корне happ-proxy.com без api часто 404 на add-install; на api.happ-proxy.com list-install может отличаться — см. HAPP_LIST_INSTALL_URL.
#
HAPP_API_URL=https://api.happ-proxy.com
HAPP_ADD_DOMAIN_URL=https://happ-proxy.com
# Только list-install (если нужен отдельно от HAPP_ADD_DOMAIN_URL)
# HAPP_LIST_INSTALL_URL=https://happ-proxy.com
# Таймаут ожидания БД в /start (сек), по умолчанию 60
# START_DB_TIMEOUT=60
# Таймаут ожидания ответа Telegram на sendMessage в /start (сек), по умолчанию 15; подстройте под TG_HTTP_TIMEOUT
# START_REPLY_TIMEOUT=15
HAPP_PROVIDER_CODE=
HAPP_AUTH_KEY=
# Ссылка подписки: https://... (базовая, бот добавит ?installid=) или happ://crypt5/... (прямая ссылка из кабинета Happ — выдаётся как есть)
HAPP_SUBSCRIPTION_URL=
# Несколько upstream подписок (через запятую): объединяем ноды в одну подписку для Happ.
# Пример:
# HAPP_SUBSCRIPTION_URLS=https://95.181.175.67:2096/sub_bitvpn/XXXXX,https://109.107.190.148:2096/sub/YYYYY
# Если не задано — используется только HAPP_SUBSCRIPTION_URL.
HAPP_SUBSCRIPTION_URLS=
# Подписи нод в Happ по порядку URL выше (через запятую, без запятой внутри названия). Пример: Wi‑Fi Нидерланды,Wi‑Fi Финляндия
# HAPP_SUBSCRIPTION_NODE_NAMES=
# Опционально: User-Agent при запросе к 3x-ui для /sub/ (по умолчанию — фиксированный «десктопный»). Иначе панель могла отдавать одну ноду для мобильного Happ и две — для браузера на ПК.
# HAPP_SUBSCRIPTION_FETCH_UA=
# Редирект: если задан, пользователь получает ссылку вида https://этот-домен/sub/КОД (реальный URL подписки не светится)
# Ссылка подписки: https://ЭТОТ_АДРЕС/sub/КОД. Можно домен (https://ваш-домен.ru) или IP (https://1.2.3.4).
HAPP_SUBSCRIPTION_REDIRECT_BASE=
# В боте и мини-аппе показывать happ://crypt* вместо HTTPS (счётчик устройств считает по ссылке из БД). true/false
HAPP_ENCRYPT_SUBSCRIPTION_LINKS=true
# Имя и описание в приложении Happ (без домена): при выдаче ссылки через /sub/ в контенте подписки подменяются на эти значения.
# Все увидят название вместо IP; подключение остаётся к серверу 95.181.175.67. Описание — как у LastdepVPN (поддержка, бот, тарифы).
# DESCRIPTION показывается одной строкой под названием (переносы из .env склеиваются) — так в Happ выглядит аккуратнее.
SUBSCRIPTION_DISPLAY_NAME=BIT VPN
SUBSCRIPTION_DESCRIPTION=Официальный сервис BIT VPN • @BitVpnProxy bot

# === Тарифы (руб, 1 устройство) ===
PLAN_1_MONTH_PRICE=100
PLAN_3_MONTH_PRICE=285
PLAN_6_MONTH_PRICE=540
PLAN_9_MONTH_PRICE=765
PLAN_12_MONTH_PRICE=960

# === Рефералы ===
REFERRAL_BONUS_PERCENT=10
REFERRAL_MIN_PAYOUT=100

# === Остальное ===
DEFAULT_LANGUAGE=ru
DEBUG=False
LOG_LEVEL=INFO
# Таймаут HTTP к Telegram API (сек). На VPS с медленным каналом увеличьте при TimedOut на старте бота
TG_HTTP_TIMEOUT=30
# Если с VPS не открывается прямое HTTPS до api.telegram.org (ConnectTimeout на start_tls): HTTP(S) прокси
# Пример: TG_PROXY=http://127.0.0.1:8118  или задайте стандартные HTTPS_PROXY / ALL_PROXY (см. httpx)
# TG_PROXY=

# === Mini App API (api_miniapp.py на сервере / Vercel) — безопасность ===
# CORS: в проде перечислите домены через запятую (мини-апп Vercel, web.telegram.org). "*" — только отладка.
# MINIAPP_CORS_ORIGINS=https://bitvpn.vercel.app,https://web.telegram.org,https://bitecosystem.ru
# Документация /docs и /openapi.json: 0=выкл (рекомендуется в проде), 1=вкл
# API_EXPOSE_DOCS=0
# Отладочные URL /api/miniapp/debug-* и check-happ-env: только при 1
# MINIAPP_EXPOSE_DEBUG=0
# Лимит POST /api/miniapp/create-payment с одного IP в минуту (по умолчанию 8)
# MINIAPP_CREATE_PAYMENT_RATE=8
# Опционально: YOOMONEY_TOKEN, QIWI_TOKEN, CRYPTOMUS_API_KEY, CRYPTOMUS_MERCHANT_ID
